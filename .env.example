# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Prisma / SQLite for dev) ---
# Dev uses a local SQLite file. For production, switch the provider in
# prisma/schema.prisma to "postgresql" and use a Postgres URL (e.g. Neon).
DATABASE_URL="file:./dev.db"

# --- Email (Resend) — wired up in Phase 3 ---
# RESEND_API_KEY=
# EMAIL_FROM="Organizer <sponsorships@example.com>"

# --- Auth (Auth.js) — wired up in Phase 2 ---
# AUTH_SECRET=

# --- App ---
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
