# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Prisma / SQLite for dev) ---
# Dev uses a local SQLite file.
DATABASE_URL="file:./dev.db"
#
# Production target: Neon/Postgres. Use the scripts ending in `:postgres`, which
# read prisma-postgres/schema.prisma and prisma-postgres/migrations.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Email (Ethereal dev / SMTP prod) ---
# Dev uses Nodemailer + Ethereal automatically — no config needed. Each sent
# email returns a preview URL in the admin action result. For production, set
# SMTP_* using a provider such as Resend SMTP.
EMAIL_FROM="Stakeholders <no-reply@stakeholders.local>"
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# --- Admin session (HS256 signing secret for jose) ---
# Generate one with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- App ---
# Set to the deployed origin, with no trailing slash. On Vercel, the app also
# falls back to VERCEL_URL if this is not set.
# NEXT_PUBLIC_SITE_URL="https://your-domain.example"

# --- Uploads ---
# Dev logo file uploads are stored in public/uploads/logos.
# Production local file uploads are intentionally disabled until object storage
# is connected. Sponsors can still paste hosted logo URLs.
