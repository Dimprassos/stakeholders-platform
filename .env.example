# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Prisma / SQLite for dev) ---
# Dev uses a local SQLite file. For production, switch the provider in
# prisma/schema.prisma to "postgresql" and use a Postgres URL (e.g. Neon).
DATABASE_URL="file:./dev.db"

# --- Email (Ethereal dev / SMTP prod) ---
# Dev uses Nodemailer + Ethereal automatically — no config needed. Each sent
# email prints a preview URL to the server console. For production, set SMTP_*.
EMAIL_FROM="Stakeholders <no-reply@stakeholders.local>"
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# --- Admin session (HS256 signing secret for jose) ---
# Generate one with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- App ---
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
