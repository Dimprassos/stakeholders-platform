# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Database (Prisma / SQLite for dev) ---
# Dev uses a local SQLite file.
DATABASE_URL="file:./dev.db"
#
# Production target: Neon/Postgres. Use the scripts ending in `:postgres`, which
# read prisma-postgres/schema.prisma and prisma-postgres/migrations.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Email (Ethereal dev / SMTP prod) ---
# Dev uses Nodemailer + Ethereal automatically — no config needed. Each sent
# email returns a preview URL in the admin action result. For production, set
# SMTP_* using a provider such as Resend SMTP.
EMAIL_FROM="Stakeholders <no-reply@stakeholders.local>"
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
#
# Optional inbound-email webhook. Point your inbound provider to:
#   POST {NEXT_PUBLIC_SITE_URL}/api/inbound-email
# Send JSON or form-data fields: from, subject, text/html, optional eventSlug,
# optional sponsorId. In production this secret is required; pass it as
# `x-inbound-secret` (or `?secret=...` for providers that only support URLs).
# INBOUND_EMAIL_WEBHOOK_SECRET="generate-with-openssl-rand-base64-32"

# --- Admin session (HS256 signing secret for jose) ---
# Generate one with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- App ---
# Set to the deployed origin, with no trailing slash. On Vercel, the app also
# falls back to VERCEL_URL if this is not set. Also used to build Stripe
# checkout success/cancel URLs, so set it correctly in production.
# NEXT_PUBLIC_SITE_URL="https://your-domain.example"

# --- Site / organizer brand (main site chrome + metadata) ---
# The main site spans every event, so its header/footer/title show the
# platform brand — NOT any single event. Per-event branding (name, logo,
# theme) is set per Event in the admin and used on /events/[slug].
# NEXT_PUBLIC_SITE_NAME="Stakeholders"
# NEXT_PUBLIC_SITE_LOGO_URL="/logo.png"
# NEXT_PUBLIC_SITE_DESCRIPTION="Explore sponsorship packages across our events."

# --- Payments (Stripe — docs/PLAN.md §16 Phase F) ---
# Test mode: create a Stripe account, then copy your TEST keys from
# https://dashboard.stripe.com/test/apikeys . Without STRIPE_SECRET_KEY the
# payment UI stays visible but "Pay now" is disabled and admins settle manually.
# STRIPE_SECRET_KEY="sk_test_..."
#
# Webhook signing secret. Locally, run `stripe listen --forward-to
# localhost:3000/api/stripe/webhook` and copy the whsec_... it prints. In prod,
# add an endpoint for {your-domain}/api/stripe/webhook and use its signing secret.
# STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Uploads ---
# Dev logo file uploads are stored in public/uploads/logos.
# Production local file uploads are intentionally disabled until object storage
# is connected. Sponsors can still paste hosted logo URLs.
