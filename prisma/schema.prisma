// Prisma schema for the Sponsorship Platform
// DB: SQLite (dev). NOTE: SQLite does not support Prisma enums or scalar lists,
// so statuses/roles are String (allowed values in comments; validated in app
// code) and `benefits` is stored as a JSON string. For production, switch the
// provider to "postgresql" and these can become real enums/arrays.
// Mirrors the data model in docs/PLAN.md §8.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Admin / organizer accounts (CMS users).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A sponsorship package / tier shown on the public packages page.
model Package {
  id           String   @id @default(cuid())
  name         String
  tier         String
  priceCents   Int
  currency     String   @default("EUR")
  benefits     String   @default("[]") // JSON array of strings
  slotsTotal   Int?
  slotsTaken   Int      @default(0)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sponsors    Sponsor[]
  submissions Submission[]
}

/// A company in the funnel. Doubles as lead/prospect and confirmed sponsor
/// via `status`; only `isPublished` ones appear on the public page.
model Sponsor {
  id           String   @id @default(cuid())
  companyName  String
  logoUrl      String?
  websiteUrl   String?
  description  String?
  packageId    String?
  package      Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  contactName  String?
  contactEmail String?
  status       String   @default("LEAD") // LEAD | CONTACTED | INTERESTED | CONFIRMED | DECLINED
  isPublished  Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  outreach Outreach[]
}

/// A public "Become a sponsor" interest-form submission.
model Submission {
  id                String   @id @default(cuid())
  companyName       String
  contactName       String
  email             String
  phone             String?
  packageInterestId String?
  packageInterest   Package? @relation(fields: [packageInterestId], references: [id], onDelete: SetNull)
  message           String?
  consentGiven      Boolean  @default(false)
  status            String   @default("NEW") // NEW | REVIEWED | CONVERTED | SPAM
  createdAt         DateTime @default(now())
}

/// A single outreach email sent (or drafted) to a prospect/sponsor.
model Outreach {
  id            String         @id @default(cuid())
  sponsorId     String?
  sponsor       Sponsor?       @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  prospectEmail String?
  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject       String
  body          String
  status        String         @default("DRAFT") // DRAFT | SENT | BOUNCED | REPLIED
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
}

/// Reusable email template with merge fields (rendered at send time).
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreach Outreach[]
}

/// Simple key/value store for event/site settings (name, dates, venue, sender).
model Setting {
  key   String @id
  value String
}
