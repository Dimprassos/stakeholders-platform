// Prisma schema for the Sponsorship Platform
// DB: SQLite (dev). NOTE: SQLite does not support Prisma enums or scalar lists,
// so statuses/roles are String (allowed values in comments; validated in app
// code) and `benefits` is stored as a JSON string. For production, switch the
// provider to "postgresql" and these can become real enums/arrays.
// Mirrors the data model in docs/PLAN.md §8 (multi-event: §16 Phase A).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Admin / organizer accounts (CMS users).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A sponsorship event / edition. Everything below (packages, sponsors,
/// submissions, templates, outreach) is scoped to one Event. One event is
/// flagged `isDefault` and drives the public site + the admin's current event.
/// (Multi-event foundation — docs/PLAN.md §16 Phase A; content & branding — Phase B.)
model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String?
  startDate   String? // ISO date string (e.g. 2026-10-21)
  endDate     String?
  venue       String?
  senderEmail String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)

  // --- Phase B: content ---
  mapUrl            String? // e.g. a Google Maps link
  currency          String  @default("EUR") // default currency for new packages
  language          String  @default("en") // BCP-47 tag, drives <html lang>
  websiteUrl        String?
  twitterUrl        String?
  linkedinUrl       String?
  instagramUrl      String?
  facebookUrl       String?
  faq               String  @default("[]") // JSON [{question, answer}]
  deadlines         String  @default("[]") // JSON [{label, date}]
  termsText         String?
  privacyText       String?
  cancellationText  String?
  agendaNote        String? // e.g. "Draft programme — subject to change"

  // --- Phase B: branding ---
  themeMode         String  @default("AUTO") // AUTO | LIGHT | DARK | CUSTOM
  brandColor        String? // hex, used when themeMode = CUSTOM
  brandInkColor     String?
  brandAccentColor  String?
  logoUrl           String?
  bannerUrl         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages    Package[]
  sponsors    Sponsor[]
  submissions Submission[]
  templates   EmailTemplate[]
  outreach    Outreach[]
  tasks       Task[]
  payments    Payment[]
  contracts   Contract[]
  agenda      AgendaItem[]
}

/// A sponsorship package / tier shown on the public packages page.
model Package {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  tier         String
  priceCents   Int
  currency     String   @default("EUR")
  benefits     String   @default("[]") // JSON array of strings
  slotsTotal   Int?
  slotsTaken   Int      @default(0)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sponsors    Sponsor[]
  submissions Submission[]

  @@index([eventId])
}

/// A company in the funnel. Doubles as lead/prospect and confirmed sponsor
/// via `status`; only `isPublished && !isHiddenFromPublic` ones appear on the
/// public page. Status pipeline (see docs/PLAN.md §8):
///   LEAD -> INVITE_SENT -> ACCEPTED -> DETAILS_SUBMITTED -> CONFIRMED
///        \-> DECLINED
model Sponsor {
  id                 String    @id @default(cuid())
  eventId            String
  event              Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  companyName        String
  logoUrl            String?
  websiteUrl         String?
  description        String?
  packageId          String?
  package            Package?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  contactName        String?
  contactEmail       String?
  status             String    @default("LEAD") // LEAD | INVITE_SENT | ACCEPTED | DETAILS_SUBMITTED | CONFIRMED | DECLINED
  isPublished        Boolean   @default(false)
  isHiddenFromPublic Boolean   @default(false)
  displayOrder       Int       @default(0)

  // Magic-link outreach fields (used in Phase 3)
  magicToken         String?   @unique
  tokenIssuedAt      DateTime?
  tokenExpiresAt     DateTime?

  // Onboarding form fields (sponsor fills these after accepting)
  legalName          String?
  billingAddress     String?
  vatNumber          String?

  // Sponsor account (docs/PLAN.md §16 Phase E). Optional: set by the sponsor
  // from their magic-link portal to enable email + password login afterwards.
  passwordHash       String?

  // Organizer CRM (docs/PLAN.md §16 Phase C): private notes about this sponsor.
  notes              String?
  // Deliverables checklist state, JSON object `{ [key]: true }` (see src/lib/deliverables.ts).
  deliverables       String    @default("{}")

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  outreach  Outreach[]
  tasks     Task[]
  payments  Payment[]
  contracts Contract[]

  @@index([eventId])
}

/// A public "Become a sponsor" interest-form submission.
model Submission {
  id                String   @id @default(cuid())
  eventId           String
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  companyName       String
  contactName       String
  email             String
  phone             String?
  packageInterestId String?
  packageInterest   Package? @relation(fields: [packageInterestId], references: [id], onDelete: SetNull)
  message           String?
  consentGiven      Boolean  @default(false)
  status            String   @default("NEW") // NEW | REVIEWED | CONVERTED | SPAM
  createdAt         DateTime @default(now())

  @@index([eventId])
}

/// A single outreach email sent (or drafted) to a prospect/sponsor.
model Outreach {
  id            String         @id @default(cuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId     String?
  sponsor       Sponsor?       @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  prospectEmail String?
  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject       String
  body          String
  direction     String         @default("OUTBOUND") // OUTBOUND | INBOUND
  status        String         @default("DRAFT") // DRAFT | SENT | BOUNCED | REPLIED
  sentAt        DateTime?
  receivedAt    DateTime?
  readAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([eventId])
  @@index([sponsorId])
}

/// One entry in an event's public programme, grouped by `day` on the agenda page.
model AgendaItem {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  day          String // ISO date (e.g. 2026-10-21) — groups items into days
  dayLabel     String? // optional heading, e.g. "Pre-Conference"
  startTime    String // "14:00"
  endTime      String? // "17:00"
  title        String
  type         String   @default("SESSION") // SESSION | KEYNOTE | BREAK | SOCIAL | REGISTRATION
  location     String?
  speaker      String?
  description  String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
}

/// Reusable email template with merge fields (rendered at send time).
model EmailTemplate {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreach Outreach[]

  @@index([eventId])
}

/// A follow-up task for a sponsor (docs/PLAN.md §16 Phase C — CRM depth):
/// e.g. "send logo", with an optional due date and done/pending state.
model Task {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId String
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  title     String
  dueDate   String? // ISO date (yyyy-mm-dd); String for SQLite parity with Event dates
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([sponsorId])
}

/// A sponsorship contract for e-signature (docs/PLAN.md §16 Phase F). The admin
/// drafts it and sends it; the sponsor reads and signs it from their portal
/// (typed name + agreement recorded with timestamp/IP as proof).
model Contract {
  id         String    @id @default(cuid())
  eventId    String
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId  String
  sponsor    Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  title      String
  body       String
  status     String    @default("DRAFT") // DRAFT | SENT | SIGNED
  signedName String? // typed full name of the signer
  signedAt   DateTime?
  signedIp   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([eventId])
  @@index([sponsorId])
}

/// A payment request against a sponsor (docs/PLAN.md §16 Phase F). The admin
/// raises it for an amount; the sponsor pays via Stripe Checkout from their
/// magic-link portal, and the webhook marks it PAID. Admins can also mark a
/// payment paid/cancelled manually for offline settlements.
model Payment {
  id                    String    @id @default(cuid())
  eventId               String
  event                 Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId             String
  sponsor               Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  amountCents           Int
  currency              String    @default("EUR")
  description           String?
  status                String    @default("PENDING") // PENDING | PAID | CANCELLED | REFUNDED
  method                String? // stripe | manual (how it was settled)
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  receiptUrl            String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([eventId])
  @@index([sponsorId])
}
