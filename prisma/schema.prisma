// Prisma schema for the Sponsorship Platform
// DB: SQLite (dev). NOTE: SQLite does not support Prisma enums or scalar lists,
// so statuses/roles are String (allowed values in comments; validated in app
// code) and `benefits` is stored as a JSON string. For production, switch the
// provider to "postgresql" and these can become real enums/arrays.
// Mirrors the data model in docs/PLAN.md §8 (multi-event: §16 Phase A).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Admin / organizer accounts (CMS users).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A sponsorship event / edition. Everything below (packages, sponsors,
/// submissions, templates, outreach) is scoped to one Event. One event is
/// flagged `isDefault` and drives the public site + the admin's current event.
/// (Multi-event foundation — docs/PLAN.md §16 Phase A; content & branding — Phase B.)
model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String?
  startDate   String? // ISO date string (e.g. 2026-10-21)
  endDate     String?
  venue       String?
  senderEmail String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)

  // --- Phase B: content ---
  mapUrl            String? // e.g. a Google Maps link
  currency          String  @default("EUR") // default currency for new packages
  language          String  @default("en") // BCP-47 tag, drives <html lang>
  websiteUrl        String?
  twitterUrl        String?
  linkedinUrl       String?
  instagramUrl      String?
  facebookUrl       String?
  faq               String  @default("[]") // JSON [{question, answer}]
  deadlines         String  @default("[]") // JSON [{label, date}]
  termsText         String?
  privacyText       String?
  cancellationText  String?

  // --- Phase B: branding ---
  themeMode         String  @default("AUTO") // AUTO | LIGHT | DARK | CUSTOM
  brandColor        String? // hex, used when themeMode = CUSTOM
  brandInkColor     String?
  brandAccentColor  String?
  logoUrl           String?
  bannerUrl         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages    Package[]
  sponsors    Sponsor[]
  submissions Submission[]
  templates   EmailTemplate[]
  outreach    Outreach[]
}

/// A sponsorship package / tier shown on the public packages page.
model Package {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  tier         String
  priceCents   Int
  currency     String   @default("EUR")
  benefits     String   @default("[]") // JSON array of strings
  slotsTotal   Int?
  slotsTaken   Int      @default(0)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sponsors    Sponsor[]
  submissions Submission[]

  @@index([eventId])
}

/// A company in the funnel. Doubles as lead/prospect and confirmed sponsor
/// via `status`; only `isPublished && !isHiddenFromPublic` ones appear on the
/// public page. Status pipeline (see docs/PLAN.md §8):
///   LEAD -> INVITE_SENT -> ACCEPTED -> DETAILS_SUBMITTED -> CONFIRMED
///        \-> DECLINED
model Sponsor {
  id                 String    @id @default(cuid())
  eventId            String
  event              Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  companyName        String
  logoUrl            String?
  websiteUrl         String?
  description        String?
  packageId          String?
  package            Package?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  contactName        String?
  contactEmail       String?
  status             String    @default("LEAD") // LEAD | INVITE_SENT | ACCEPTED | DETAILS_SUBMITTED | CONFIRMED | DECLINED
  isPublished        Boolean   @default(false)
  isHiddenFromPublic Boolean   @default(false)
  displayOrder       Int       @default(0)

  // Magic-link outreach fields (used in Phase 3)
  magicToken         String?   @unique
  tokenIssuedAt      DateTime?
  tokenExpiresAt     DateTime?

  // Onboarding form fields (sponsor fills these after accepting)
  legalName          String?
  billingAddress     String?
  vatNumber          String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  outreach Outreach[]

  @@index([eventId])
}

/// A public "Become a sponsor" interest-form submission.
model Submission {
  id                String   @id @default(cuid())
  eventId           String
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  companyName       String
  contactName       String
  email             String
  phone             String?
  packageInterestId String?
  packageInterest   Package? @relation(fields: [packageInterestId], references: [id], onDelete: SetNull)
  message           String?
  consentGiven      Boolean  @default(false)
  status            String   @default("NEW") // NEW | REVIEWED | CONVERTED | SPAM
  createdAt         DateTime @default(now())

  @@index([eventId])
}

/// A single outreach email sent (or drafted) to a prospect/sponsor.
model Outreach {
  id            String         @id @default(cuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId     String?
  sponsor       Sponsor?       @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  prospectEmail String?
  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subject       String
  body          String
  status        String         @default("DRAFT") // DRAFT | SENT | BOUNCED | REPLIED
  sentAt        DateTime?
  createdAt     DateTime       @default(now())

  @@index([eventId])
}

/// Reusable email template with merge fields (rendered at send time).
model EmailTemplate {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreach Outreach[]

  @@index([eventId])
}
